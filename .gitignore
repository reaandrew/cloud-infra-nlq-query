# Local .terraform directories
**/.terraform/*

# Node.js dependencies
node_modules/

# .tfstate files
*.tfstate
*.tfstate.*

# Crash log files
crash.log
crash.*.log

# Exclude all .tfvars files, which are likely to contain sensitive data
*.tfvars
*.tfvars.json

# Ignore override files as they are usually used for local development
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Ignore CLI configuration files
.terraformrc
terraform.rc

# Ignore Lambda function zip files
*.zip

# Ignore any local environment files
.env
.env.*

# Ignore IDE specific files
.idea/
.vscode/
*.swp
*.swo
.terraform.lock.hcl

# Fetched AWS Config resource schemas (pulled from awslabs/aws-config-resource-schema)
data/config_resource_schemas/

# Pre-generated AWS event schemas (regenerate via scripts/generate_aws_event_schemas.sh)
data/aws_event_schemas/
